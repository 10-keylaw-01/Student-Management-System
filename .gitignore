# ── Compiled C++ binaries ─────────────────────────────────────────────────────
*.exe
*.out
*.o
sms
sms_*
main.exe

# ── Windows shortcut files ─────────────────────────────────────────────────────
*.lnk

# ── MinGW / GCC runtime DLLs (not needed in source control) ───────────────────
libstdc++*.dll
libgcc*.dll
libwinpthread*.dll

# ── Debug / test / scratch files ──────────────────────────────────────────────
debug_login.cpp
hash_tool.cpp
input.txt
test_*.txt

# ── Runtime state files ───────────────────────────────────────────────────────
.lockout

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd

# ── Python virtual environments ───────────────────────────────────────────────
venv/
.venv/
env/

# ── IDE / editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Matplotlib cache ──────────────────────────────────────────────────────────
.matplotlib/

# ── Generated assets (recreated by generate_icon.py) ──────────────────────────
frontend/resources/icons/default_icon.png
frontend/resources/icons/default_logo.png

