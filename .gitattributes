# Normalize line endings: LF in repo, platform-native on checkout
* text=auto

# Force LF for source files (keeps diffs clean on Windows)
*.py    text eol=lf
*.cpp   text eol=lf
*.h     text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.qss   text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.csv   text eol=lf

# Windows scripts — keep CRLF so cmd.exe runs them correctly
*.bat   text eol=crlf

# Binaries — no line-ending conversion
*.exe   binary
*.dll   binary
*.ico   binary
*.png   binary
